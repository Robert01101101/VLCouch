# Optional: override VLC path (auto-detected on Windows if not set)
# VLC_PATH=C:\Program Files\VideoLAN\VLC\vlc.exe

# Optional path to ffmpeg.exe (auto-detected from PATH if not set)
# FFMPEG_PATH=C:\ffmpeg\bin\ffmpeg.exe

# Media library roots (JSON array). Each entry: {"path": "D:/Movies", "type": "movies"|"tv"}
MEDIA_ROOTS=[{"path":"D:/Movies","type":"movies"},{"path":"D:/TV","type":"tv"}]

# Wikipedia plot summaries on detail pages only (text, no images). Fully offline when false.
METADATA_ENABLED=false

# Seconds to skip before grabbing a video frame (avoids studio logos)
THUMBNAIL_SKIP_SECONDS=180

# Max items per row on the home page
ROW_ITEM_LIMIT=30

# Max files scanned per media root (0 = no limit). Rescan always scans everything.
SCAN_LIMIT=0

# Scan only when you click Rescan Library (not on server startup)
SCAN_ON_STARTUP=false
