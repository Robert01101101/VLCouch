# Copy to .env at repo root when running tests manually (optional — pytest sets APP_ENV=test automatically)
#   copy docs\.env.test.example .env

APP_ENV=test
TEST_MODE=true
SCAN_ON_STARTUP=false
METADATA_ENABLED=false

# Optional overrides (defaults use backend/tests/fixtures/media/)
# TEST_DB_PATH=backend/tests/.tmp/library.db
# TEST_MEDIA_ROOTS=[{"path":"backend/tests/fixtures/media/movies","type":"movies"},{"path":"backend/tests/fixtures/media/tv","type":"tv"}]
